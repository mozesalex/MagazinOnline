@{
    ViewData["Title"] = "Home Page";
}

<style>
    .hero-section {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        height: 100vh;
        text-align: center;
        background: linear-gradient(to right, #007bff, #6a0dad); 
        color: white;
    }

    .hero-title {
        font-size: 9rem;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .hero-subtitle {
